  "info": {
    "title": "Hospital Management System API",
    "description": "In-memory backend for Review-4",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "x-role": {
        "type": "apiKey",
        "in": "header",
        "name": "x-role"
      }
    },
    "schemas": {
      "CreateDoctorDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Dr. Smith",
            "description": "Full name of the doctor"
          },
          "specialization": {
            "type": "string",
            "example": "Cardiology",
            "description": "Doctor specialization"
          },
          "start": {
            "type": "string",
            "example": "9:00 AM",
            "description": "Shift start time"
          },
          "end": {
            "type": "string",
            "example": "5:00 PM",
            "description": "Shift end time"
          },
          "status": {
            "type": "string",
            "example": "Available",
            "description": "Doctor availability status",
            "enum": [
              "Available",
              "Not Available"
            ],
            "default": "Available"
          }
        },
        "required": [
          "name",
          "specialization",
          "start",
          "end",
          "status"
        ]
      },
      "CreatePatientDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "FED-2026-9001"
          },
          "name": {
            "type": "string",
            "example": "Arun Mehta"
          },
          "age": {
            "type": "string",
            "example": "54"
          },
          "gender": {
            "type": "string",
            "example": "Male"
          },
          "phone": {
            "type": "string",
            "example": "9876543210"
          },
          "address": {
            "type": "string",
            "example": "Banjara Hills"
          },
          "email": {
            "type": "string",
            "example": "arun.mehta@example.com"
          }
        },
        "required": [
          "name",
          "age",
          "gender",
          "phone",
          "address"
        ]
      },
      "CreateLedgerEntryDto": {
        "type": "object",
        "properties": {
          "entry_id": {
            "type": "number",
            "example": 1
          },
          "service_name": {
            "type": "string",
            "example": "Consultation"
          },
          "qty": {
            "type": "number",
            "example": 1
          },
          "price": {
            "type": "number",
            "example": 500
          },
          "tax": {
            "type": "number",
            "example": 0
          },
          "ts": {
            "type": "number",
            "example": 1714853856123
          }
        },
        "required": [
          "service_name",
          "qty",
          "price",
          "tax"
        ]
      },
      "CreateReceiptDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "example": 901
          },
          "patient": {
            "type": "string",
            "example": "Rahul Verma"
          },
          "uhid": {
            "type": "string",
            "example": "FED-2026-TEST01"
          },
          "amount": {
            "type": "number",
            "example": 3100
          },
          "gross": {
            "type": "number",
            "example": 4600
          },
          "coverage": {
            "type": "number",
            "example": 1500
          },
          "insurance": {
            "type": "string",
            "example": "Star Health"
          },
